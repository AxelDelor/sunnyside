<div class="container-fluid">
  <div class="row g-2 page-content p-3">
    <div class="col-12 col-lg-8 order-1 order-lg-2">
      <div id="map"
      class="card map-card"
      data-controller="map"
      data-map-bars-value="<%= @all_bars.to_json(only: [:id, :name, :latitude, :longitude, :address]) %>">
      </div>
    </div>
    <div class="col-12 col-lg-4 order-2 order-lg-1">
      <div class="card favorites-card" style="overflow-y: auto;">
        <div class="card-header fw-bold">Mes Favoris</div>
        <ul id="favorites_list" class="list-group list-group-flush">
          <% if @favorites.any? %>
            <%= render @favorites %>
          <% else %>
            <li class="list-group-item" id="no-favorites-message">Vous n'avez pas encore de favoris.</li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
